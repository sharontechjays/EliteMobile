{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@app/*": ["src/modules/app/*"],
      "@modules/*": ["src/modules/*"],
      "@native/*": ["modules/*"]
    }
  },
  "include": ["src", "app", "modules"]
}
